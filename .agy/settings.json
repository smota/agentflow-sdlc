{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const c=require('child_process');process.exit(c.spawnSync(process.execPath,[c.execFileSync('git',['rev-parse','--show-toplevel'],{encoding:'utf8'}).trim()+'/.github/hooks/session-status.mjs'],{stdio:'inherit'}).status||0)\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const c=require('child_process');process.exit(c.spawnSync(process.execPath,[c.execFileSync('git',['rev-parse','--show-toplevel'],{encoding:'utf8'}).trim()+'/.github/hooks/check-issue-branch.mjs'],{stdio:'inherit'}).status||0)\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const c=require('child_process');process.exit(c.spawnSync(process.execPath,[c.execFileSync('git',['rev-parse','--show-toplevel'],{encoding:'utf8'}).trim()+'/.github/hooks/check-commit-ready.mjs'],{stdio:'inherit'}).status||0)\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const c=require('child_process');process.exit(c.spawnSync(process.execPath,[c.execFileSync('git',['rev-parse','--show-toplevel'],{encoding:'utf8'}).trim()+'/.github/hooks/prettier-on-write.mjs'],{stdio:'inherit'}).status||0)\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const c=require('child_process');process.exit(c.spawnSync(process.execPath,[c.execFileSync('git',['rev-parse','--show-toplevel'],{encoding:'utf8'}).trim()+'/.github/hooks/post-commit-summary.mjs'],{stdio:'inherit'}).status||0)\""
          }
        ]
      }
    ]
  }
}
